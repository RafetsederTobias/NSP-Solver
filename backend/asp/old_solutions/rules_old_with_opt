% ELIGIBILITY

% A user is eligible for a station if they have all required skills.
% Precomputing this drastically reduces the search space in the choice rule.
eligible(U, S) :-
    user(U), station(S),
    #count { Sk : requires(S, Sk), not has_skill(U, Sk) } = 0.

% CHOICE RULE — core assignment generation

% Assign between 0 and Max eligible users to each station each day.
% No hard lower bound
{ assigned(U, S, D) : eligible(U, S) } Max :-
    station(S), day(D), max_assignments(S, Max).

% HARD CONSTRAINTS

% A user can only work one station per day.
:- user(U), day(D),
   #count { S : assigned(U, S, D) } > 1.

% A user cannot be assigned on a blocked day.
:- assigned(U, _, D), blocked_day(U, D).

% A user must be assigned on their fixed days.
:- user(U), fixed_day(U, D), day(D), not assigned(U, _, D).

% Max days per month constraint.
:- user(U), max_days(U, Max),
   #count { D : assigned(U, _, D) } > Max.

% Min days per month constraint.
:- user(U), min_days(U, Min),
   #count { D : assigned(U, _, D) } < Min.

% Exact days per month constraint.
:- user(U), exact_days(U, Exact),
   #count { D : assigned(U, _, D) } != Exact.

% STAFFING QUALITY - derived facts for optimization

% Number of users assigned to a station on a given day.
staff_count(S, D, N) :-
    station(S), day(D),
    N = #count { U : assigned(U, S, D) }.

% A station is unstaffed if it has zero users on a given day.
unstaffed(S, D) :-
    station(S), day(D),
    staff_count(S, D, 0).

% A station is understaffed if it has fewer than max users (but at least 1).
understaffed(S, D) :-
    station(S), day(D),
    max_assignments(S, Max),
    staff_count(S, D, N),
    N > 0, N < Max.

% OPTIMIZATION

% Priority @2: minimize unstaffed stations 
% Priority @1: minimize understaffed stations
% Weight 10 vs 1 ensures any unstaffed station is worse than all understaffing.
#minimize {
    10@2, S, D : unstaffed(S, D);
     1@1, S, D : understaffed(S, D)
}.